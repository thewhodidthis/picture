{
  "name": "@thewhodidthis/picture",
  "version": "0.1.1",
  "description": "Helps setup canvas drawings",
  "keywords": [
    "canvas"
  ],
  "main": "index.js",
  "module": "index.es",
  "homepage": "https://github.com/thewhodidthis/picture#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thewhodidthis/picture.git"
  },
  "bugs": {
    "url": "https://github.com/thewhodidthis/picture/issues"
  },
  "scripts": {
    "pretest": "eslint test.js",
    "test": "rollup -c node:x -f iife test.js | kpow",
    "prestart": "eslint index.es",
    "start": "rollup -f cjs index.es > index.js",
    "preexample": "eslint example --ext es,js --ignore-pattern index.js",
    "example": "cd example; rollup -f iife index.es | buble > index.js",
    "postexample": "open example/index.html"
  },
  "eslintConfig": {
    "extends": "@thewhodidthis"
  },
  "engines": {
    "node": ">=6.4.0",
    "npm": ">=3.10.3"
  },
  "dependencies": {},
  "devDependencies": {
    "@thewhodidthis/eslint-config": "latest",
    "buble": "latest",
    "cutaway": "latest",
    "eslint": "latest",
    "kpow": "latest",
    "rollup": "latest",
    "rollup-config-x": "latest",
    "tapeless": "latest"
  },
  "author": "sChzs BkgNns <sotirios.bakagiannis@gmail.com> (https://www.thewhodidthis.com)",
  "license": "Unlicense"
}
