{
  "name": "@thewhodidthis/picture",
  "version": "0.0.5",
  "description": "Helps setup canvas drawings",
  "keywords": [
    "canvas",
    "drawing",
    "picture",
    "sprite"
  ],
  "main": "index.js",
  "module": "index.es",
  "homepage": "https://github.com/thewhodidthis/picture#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thewhodidthis/picture.git"
  },
  "bugs": {
    "url": "https://github.com/thewhodidthis/picture/issues"
  },
  "directories": {
    "example": "example"
  },
  "config": {
    "remote": "thewhodidthis@zazie:www/example/picture/"
  },
  "scripts": {
    "test": "browserify test/*.js | testling -x open",
    "clear": "npm run clear:dist && npm run clear:logs",
    "clear:dist": "rm -rf dist/",
    "clear:docs": "rm -rf docs/",
    "clear:logs": "rm -f *.log",
    "lint": "eslint index.es; exit 0",
    "lint:test": "eslint test/index.js; exit 0",
    "docs": "docco -l ivory -e .js index.es",
    "start": "npm run build && npm run build:min",
    "preexample": "npm start",
    "example": "npm run example:build && npm run example:serve",
    "example:push": "rsync -avruzLPC --exclude=.DS_Store ./example/ $npm_package_config_remote",
    "example:build": "find example -type d ! -path '*/lib' -exec rollup -o {}/build.js -f iife {}/index.js \\;",
    "example:serve": "php -S localhost:8000 -t example/",
    "build": "rollup -c",
    "build:min": "uglifyjs dist/picture.js -cm > dist/picture.min.js",
    "preversion": "npm start"
  },
  "engines": {
    "node": ">=4.2.4",
    "npm": ">=3.5.3"
  },
  "dependencies": {},
  "devDependencies": {
    "babel-eslint": "latest",
    "babel-plugin-external-helpers": "latest",
    "babel-preset-es2015": "latest",
    "browserify": "latest",
    "docco": "github:67656e65726963/docco",
    "eslint": "latest",
    "eslint-config-airbnb-base": "latest",
    "eslint-plugin-import": "latest",
    "rollup": "latest",
    "rollup-plugin-babel": "latest",
    "rollup-watch": "latest",
    "tape": "latest",
    "testling": "latest",
    "uglify-js": "latest"
  },
  "author": "sChzs BkgNns <sotirios.bakagiannis@gmail.com> (https://www.thewhodidthis.com)",
  "license": "Unlicense"
}
